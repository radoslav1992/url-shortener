{
  "name": "url-shortener",
  "type": "module",
  "version": "1.0.0",
  "description": "A fast, SEO-friendly URL shortener built with Astro, deployed on Cloudflare with D1 storage and AdSense monetization.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "db:init": "wrangler d1 execute url_shortener --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute url_shortener --remote --file=./schema.sql",
    "db:migrate": "wrangler d1 execute url_shortener --local --file=./migrations/0001_abuse_prevention.sql",
    "db:migrate:remote": "wrangler d1 execute url_shortener --remote --file=./migrations/0001_abuse_prevention.sql",
    "og": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.5.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^5.7.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.3",
    "wrangler": "^4.10.0"
  }
}
