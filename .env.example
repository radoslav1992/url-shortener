# Copy to .dev.vars for local `wrangler` dev, or set in the Cloudflare dashboard.

# Public base URL of your deployment (used for short links + SEO canonical tags).
PUBLIC_SITE_URL="https://shr7.org"

# Google AdSense publisher ID, e.g. "ca-pub-1234567890123456".
# Leave empty to disable ads entirely.
PUBLIC_ADSENSE_CLIENT=""

# --- Abuse prevention ---

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
PUBLIC_TURNSTILE_SITE_KEY=""   # public site key, rendered in the form
TURNSTILE_SECRET_KEY=""         # secret key, server-side verification

# Google Safe Browsing API key (https://console.cloud.google.com → enable
# "Safe Browsing API"). Used to reject phishing/malware destinations.
SAFE_BROWSING_API_KEY=""

# Note: in production, set TURNSTILE_SECRET_KEY and SAFE_BROWSING_API_KEY as
# secrets (`wrangler secret put NAME`), not as plain vars. If a key is empty
# that particular check is skipped.
