---
import Layout from '../layouts/Layout.astro';
import AdSense from '../components/AdSense.astro';

export const prerender = false;

const turnstileSiteKey =
  Astro.locals.runtime?.env?.PUBLIC_TURNSTILE_SITE_KEY ||
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ||
  '';

// Cross-promoted free tools. Logos load each site's favicon at runtime (with a
// letter-tile fallback), so no third-party assets are bundled.
const tools = [
  {
    name: '10 Minute Mailbox',
    domain: '10minmailbox.com',
    url: 'https://10minmailbox.com/',
    description:
      'Free temporary email. Get a disposable inbox that expires automatically, so you can sign up anywhere without giving out your real address or getting spam.',
    accent: '#2f8f6b',
  },
  {
    name: 'Whisper STT',
    domain: 'whisperstt.com',
    url: 'https://whisperstt.com/',
    description:
      'Free speech-to-text. Turn audio and voice recordings into accurate text in seconds with Whisper-powered transcription.',
    accent: '#5b6ee1',
  },
];

// Question/answer content drives both the visible FAQ and the FAQPage schema —
// concise, factual answers are exactly what generative engines cite.
const faqs = [
  {
    q: 'What is SHR7?',
    a: 'SHR7 is a free URL shortener that turns long links into short, shareable ones and tracks real-time click statistics. It runs on Cloudflare’s global edge network, so links redirect in milliseconds worldwide.',
  },
  {
    q: 'Is SHR7 free to use?',
    a: 'Yes. Shortening links and viewing their statistics is completely free, and no account or sign-up is required.',
  },
  {
    q: 'How do I track clicks on a short link?',
    a: 'Open the Statistics page and enter your short code (or paste the full short link) to see total clicks, a 7-day trend, top referrers and visitor countries.',
  },
  {
    q: 'Can I choose a custom short link?',
    a: 'Yes. When creating a link you can set a custom alias of 3–32 letters, numbers, hyphens or underscores, as long as it isn’t already taken.',
  },
  {
    q: 'How long do SHR7 links last?',
    a: 'Short links stay active indefinitely unless they are reported and disabled for abuse such as spam, phishing or malware.',
  },
];

const structuredData = [
  {
    '@type': 'WebApplication',
    name: 'SHR7',
    applicationCategory: 'UtilitiesApplication',
    operatingSystem: 'Any',
    url: 'https://shr7.org/',
    description:
      'Free URL shortener with real-time click analytics, built on Cloudflare.',
    featureList: [
      'Shorten long URLs',
      'Custom aliases',
      'Real-time click statistics',
      'Top referrers and countries',
      'Edge redirects',
    ],
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@type': 'HowTo',
    name: 'How to shorten a URL with SHR7',
    step: [
      { '@type': 'HowToStep', name: 'Paste your URL', text: 'Paste a long URL into the box on the SHR7 home page.' },
      { '@type': 'HowToStep', name: 'Shorten it', text: 'Click “Shorten URL” to get a short link instantly.' },
      { '@type': 'HowToStep', name: 'Share and track', text: 'Share the short link, then check its statistics anytime.' },
    ],
  },
  {
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Layout structuredData={structuredData}>
  <section class="mx-auto max-w-2xl text-center">
    <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-line bg-white px-3 py-1 text-xs font-medium text-ink-muted">
      <span class="h-1.5 w-1.5 rounded-full bg-clay-400"></span>
      Free · No sign-up · Built on Cloudflare
    </p>
    <h1 class="text-balance text-4xl font-semibold sm:text-5xl">
      Shorten links.<br />Watch them work.
    </h1>
    <p class="mx-auto mt-4 max-w-xl text-balance text-lg text-ink-muted">
      Turn long, unwieldy URLs into clean short links — then track every click
      with real-time statistics.
    </p>
  </section>

  <!-- Shortener form -->
  <section class="mx-auto mt-10 max-w-2xl">
    <form id="shorten-form" class="card flex flex-col gap-4">
      <div>
        <label for="url" class="mb-1.5 block text-sm font-medium text-ink-soft">
          Long URL
        </label>
        <input
          id="url"
          name="url"
          type="text"
          inputmode="url"
          autocomplete="off"
          placeholder="https://example.com/a-very-long-link-to-shorten"
          class="input"
          required
        />
      </div>

      <details class="group">
        <summary class="cursor-pointer text-sm font-medium text-ink-muted hover:text-ink">
          Custom alias (optional)
        </summary>
        <div class="mt-2 flex items-center gap-2">
          <span class="text-sm text-ink-muted">/</span>
          <input
            id="alias"
            name="alias"
            type="text"
            autocomplete="off"
            placeholder="my-link"
            class="input"
            pattern="[A-Za-z0-9_-]{3,32}"
          />
        </div>
      </details>

      {
        turnstileSiteKey && (
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-theme="light"
            data-size="flexible"
          />
        )
      }

      <button type="submit" id="submit-btn" class="btn-primary w-full">
        Shorten URL
      </button>

      <p id="form-error" class="hidden text-sm text-clay-600" role="alert"></p>
    </form>

    <!-- Result -->
    <div id="result" class="card mt-4 hidden">
      <p class="mb-2 text-sm font-medium text-ink-muted">Your short link</p>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          id="result-link"
          href="#"
          target="_blank"
          rel="noopener"
          class="flex-1 truncate rounded-xl border border-line bg-cream-100 px-4 py-3 font-medium text-clay-500"
        ></a>
        <div class="flex gap-2">
          <button id="copy-btn" type="button" class="btn-ghost">Copy</button>
          <a id="stats-link" href="#" class="btn-ghost">Stats</a>
        </div>
      </div>
    </div>
  </section>

  <!-- More free tools -->
  <section class="mx-auto mt-12 max-w-2xl">
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold">More free tools</h2>
      <span class="h-px flex-1 bg-line"></span>
    </div>
    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      {
        tools.map((t) => (
          <a
            href={t.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card group flex items-start gap-4 transition-colors hover:bg-cream-100"
          >
            <span
              class="relative flex h-11 w-11 shrink-0 items-center justify-center overflow-hidden rounded-xl text-base font-semibold text-white"
              style={`background:${t.accent}`}
            >
              <span aria-hidden="true">{t.name.charAt(0)}</span>
              <img
                src={`https://www.google.com/s2/favicons?domain=${t.domain}&sz=128`}
                alt={`${t.name} logo`}
                width="44"
                height="44"
                loading="lazy"
                class="absolute inset-0 h-full w-full bg-white object-contain p-1.5"
                onerror="this.remove()"
              />
            </span>
            <span class="min-w-0">
              <span class="flex items-center gap-1 font-medium text-ink">
                {t.name}
                <svg
                  class="text-ink-muted opacity-0 transition-opacity group-hover:opacity-100"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M7 17 17 7" />
                  <path d="M7 7h10v10" />
                </svg>
              </span>
              <p class="mt-1 text-sm text-ink-muted">{t.description}</p>
              <span class="mt-2 inline-block text-xs text-clay-500">{t.domain}</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  {
    turnstileSiteKey && (
      <script
        src="https://challenges.cloudflare.com/turnstile/v0/api.js"
        async
        is:inline
      />
    )
  }

  <!-- Ad slot -->
  <section class="mx-auto mt-10 max-w-2xl">
    <AdSense slot="0000000000" />
  </section>

  <!-- Features / SEO content -->
  <section class="mx-auto mt-16 max-w-4xl">
    <h2 class="text-center text-2xl font-semibold">Why SHR7?</h2>
    <div class="mt-8 grid gap-5 sm:grid-cols-3">
      <div class="card">
        <h3 class="text-lg font-semibold">Blazing fast</h3>
        <p class="mt-2 text-sm text-ink-muted">
          Redirects run on Cloudflare's global edge network, so your links
          resolve in milliseconds anywhere in the world.
        </p>
      </div>
      <div class="card">
        <h3 class="text-lg font-semibold">Real analytics</h3>
        <p class="mt-2 text-sm text-ink-muted">
          See total clicks, daily trends, top referrers and visitor countries
          for any link you create.
        </p>
      </div>
      <div class="card">
        <h3 class="text-lg font-semibold">Privacy-friendly</h3>
        <p class="mt-2 text-sm text-ink-muted">
          No account required. We store only what's needed to count clicks —
          never your personal data.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ — concise answers for both readers and generative search engines -->
  <section class="mx-auto mt-16 max-w-3xl">
    <h2 class="text-center text-2xl font-semibold">Frequently asked questions</h2>
    <dl class="mt-8 space-y-3">
      {
        faqs.map((f) => (
          <details class="card group">
            <summary class="cursor-pointer list-none font-medium text-ink marker:hidden">
              <dt class="inline">{f.q}</dt>
            </summary>
            <dd class="mt-3 text-sm text-ink-muted">{f.a}</dd>
          </details>
        ))
      }
    </dl>
  </section>
</Layout>

<script>
  const form = document.getElementById('shorten-form') as HTMLFormElement;
  const errorEl = document.getElementById('form-error') as HTMLParagraphElement;
  const result = document.getElementById('result') as HTMLDivElement;
  const resultLink = document.getElementById('result-link') as HTMLAnchorElement;
  const statsLink = document.getElementById('stats-link') as HTMLAnchorElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Shortening…';

    const data = new FormData(form);
    try {
      const res = await fetch('/api/shorten', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          url: data.get('url'),
          alias: data.get('alias') || undefined,
          turnstileToken: data.get('cf-turnstile-response') || undefined,
        }),
      });
      const payload = await res.json();
      if (!res.ok) throw new Error(payload.error || 'Something went wrong.');

      resultLink.textContent = payload.shortUrl;
      resultLink.href = payload.shortUrl;
      statsLink.href = '/stats?code=' + encodeURIComponent(payload.code);
      result.classList.remove('hidden');
      form.reset();
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong.';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Shorten URL';
      // Reset the Turnstile widget so the next submit gets a fresh token.
      const ts = (window as unknown as { turnstile?: { reset: () => void } }).turnstile;
      if (ts) ts.reset();
    }
  });

  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(resultLink.textContent || '');
      const original = copyBtn.textContent;
      copyBtn.textContent = 'Copied!';
      setTimeout(() => (copyBtn.textContent = original), 1500);
    } catch {
      /* clipboard unavailable */
    }
  });
</script>
