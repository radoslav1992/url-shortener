---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found — Snip" description="The page or short link you requested could not be found." noindex>
  <section class="mx-auto max-w-lg py-16 text-center">
    <p class="font-serif text-6xl font-semibold text-clay-400">404</p>
    <h1 class="mt-4 text-2xl font-semibold">Link not found</h1>
    <p class="mt-3 text-ink-muted">
      This short link doesn't exist or may have been removed. Double-check the
      code, or create a fresh one.
    </p>
    <div class="mt-6 flex justify-center gap-3">
      <a href="/" class="btn-primary">Shorten a URL</a>
      <a href="/stats" class="btn-ghost">Check stats</a>
    </div>
  </section>
</Layout>
