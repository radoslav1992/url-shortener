---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Shorten' },
  { href: '/stats', label: 'Statistics' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-line bg-cream/80 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
    <a href="/" class="flex items-center gap-2.5 text-ink">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-clay-400 text-white"
        aria-hidden="true"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
      </span>
      <span class="font-serif text-lg font-semibold tracking-tight">SHR7</span>
    </a>

    <ul class="flex items-center gap-1">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                path === l.href
                  ? 'bg-cream-200 text-ink'
                  : 'text-ink-muted hover:bg-cream-100 hover:text-ink',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
